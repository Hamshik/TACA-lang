{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch MyComplier",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Complier",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                
                {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
            ],
            "preLaunchTask": "build MyComplier(build.sh)",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Launch MyCompiler(gcc)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/MyComplier",
            "args": [
                "examples/source/test.sasm"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build MyComplier(gcc)"
        },
        {
            "name": "Launch MyCompiler(clang)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/MyComplier",
            "args": [
                "examples/source/test.sasm"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                }
            ],
            "preLaunchTask": "build MyComplier(clang)"
        }
    ]

}
