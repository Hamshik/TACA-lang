{
	"$schema": "../schemas/textmate-grammar.schema.json",
	"name": "Tarkic",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#types"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.block.tarkic",
					"begin": "'''",
					"end": "'''"
				},
				{
					"name": "comment.line.tarkic",
					"match": "''(?!').*$"
				}
			]
		},
		"keywords": {
			"patterns": [{
				"name": "keyword.control.tarkic",
				"match": "\\b(if|else|while|for|fn|ret|return|mut|var|immut|let)\\b"
			}]
		},
		"types": {
			"patterns": [{
				"name": "storage.type.tarkic",
				"match": "\\b(i8|i16|i32|i128|u8|u16|u32|u64|u128|f32|f64|f128|uf32|uf64|uf128|str|char|bool|void)\\b"
			}]
		},
		"numbers": {
			"patterns": [{
				"name": "constant.numeric.tarkic",
				"match": "\\b\\d+(?:\\.\\d+)?\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.tarkic",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.tarkic",
					"match": "\\\\."
				}
			]
		},
		"operators": {
			"patterns": [{
				"name": "keyword.operator.tarkic",
				"match": "(\\+\\+|--|\\*\\*=?|<<=?|>>=?|==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|=|&&|\\|\\||[+\\-*/%<>!~&|^:;,])"
			}]
		}
	},
	"scopeName": "source.tarkic"
}
