fn i32 main() {
    mut i32 size = 8;
    mut i32 count = 4;
    mut i32& local_ref = &size;
    mut ptr_a = alloc(size);
    mut ptr_b = calloc(count, size);
    mut ptr_c = realloc(ptr_b, 64);

    println(type(ptr_a));
    println(type(local_ref));

    memcpy(ptr_a, ptr_c, size);
    memncpy(ptr_c, count, ptr_a, size);
    rm(ptr_a);
    rm(ptr_c);

    return 0;
}
