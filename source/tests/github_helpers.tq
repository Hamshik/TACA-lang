#import "source/tests/github_labels.tq";

fn i32 clamp_score(i32 value, i32 floor, i32 ceil) {
    if {value < floor} {
        return floor;
    } else {
        if {value > ceil} {
            return ceil;
        } else {
            return value;
        }
    }
}

fn i32 score_pr(i32 additions, i32 deletions, i32 review_comments) {
    mut i32 score = additions - deletions;
    score += review_comments * 3;
    return clamp_score(score, 0, 100);
}

fn bool is_even(i32 value) {
    return value % 2 == 0;
}

fn char pass_badge() {
    return green_badge();
}
