// Multi-declaration demo (parser expands into AST_SEQ of normal declarations)

var int32 a = 1, b = 2, c = 3;
let int32 x = 10, y = 20;
let int32 m = 1, str s = "hi", bool ok = true;

// Block form (semicolon separated)
let {
    int32 p = 7;
    str msg = "block-ok";
    bool flag = true;
}

// Use the variables so eval prints them
a;
b;
c;
x + y;
m;
s;
ok;
p;
msg;
flag;

