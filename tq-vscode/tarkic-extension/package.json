{
  "name": "tarkic-extension",
  "publisher": "hamshik",
  "displayName": "Tarkic Extension",
  "description": "Syntax highlighter for Tarkic-lang",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "tarkic",
      "aliases": ["Tarkic", "tarkic"],
      "extensions": [".tq"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "tarkic",
      "scopeName": "source.tarkic",
      "path": "./syntaxes/tarkic.tmLanguage.json"
    }]
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/hamshik/tarkiq"
  }

}
