{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	    "version": "0.2.0",
	    "configurations": [
	        {
	            "name": "Launch MyComplier",
	            "type": "cppdbg",
	            "request": "launch",
	            "program": "${workspaceFolder}/bin/taca",
	            "args": [
					"${workspaceFolder}/source/test.tq",
					"-o",
					"${workspaceFolder}/output/test",
					"--emit-ir",
					"${workspaceFolder}/output/test.ll",
				],
	            "cwd": "${workspaceFolder}",
	            "stopAtEntry": false,
	            "externalConsole": false,
	            "MIMode": "gdb",
	            "setupCommands": [             
	                {
	                    "description": "Enable pretty-printing for gdb",
	    	            "text": "-enable-pretty-printing",
	                    "ignoreFailures": false
	                },
					{
						"description": "Disable debuginfod",
						"text": "set debuginfod enabled off",
						"ignoreFailures": false
					}
	            ],
	            "preLaunchTask": "build the Complier",
	            "internalConsoleOptions": "neverOpen"
	        }
	    ]

	}
