fn i32 main() {
    mut i32 a = 9;
    mut i32 b = 4;
    mut bool ready = true;

    println(a + b);
    println(a - b);
    println(a * b);
    println(a / b);
    println(a % b);
    println(a ** 2);

    println(a << 1);
    println(a >> 1);
    println(a & b);
    println(a | b);
    println(a ^ b);
    println(~a);

    println(a == b);
    println(a != b);
    println(a > b);
    println(a >= b);
    println(a < b);
    println(a <= b);

    println(ready && true);
    println(ready || false);
    println(!ready);

    return 0;
}
